ENV=dev
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
SUPABASE_JWT_SECRET=U3Y67sEwOZmSkf0h4sFzCxRxN3JokAHeqEyVplngSxeDsydyImW31nMzu4YpMEUmWDtgYALC6eE5ORoJ4yT+dQ==

# 图像处理配置
APP_NAME=古文字简牍图像处理系统
APP_VERSION=1.0.0

# 文件存储
UPLOAD_DIR=./uploads
RESULT_DIR=./results
TEMP_DIR=./temp
MAX_FILE_SIZE=52428800

# 图像处理参数
DEFAULT_IMAGE_QUALITY=95
THUMBNAIL_SIZE=800

# 单支简牍 YOLOv8 检测（可选）
# 配置后优先使用 YOLOv8 检测单支，未配置则使用 OpenCV 轮廓检测
# 模型文件需自行准备，例如从 Ultralytics 导出或自训练 yolov8l.pt
YOLOV8_SLIP_MODEL_PATH=models/yolov8l.pt
# 仅保留该类别 id；2 分类时常见 1=单支、0=背景，若过滤后为 0 框可改为 1（代码也会自动尝试数量最多的类别）
YOLOV8_SLIP_CLASS_ID=1
# 置信度阈值
YOLOV8_SLIP_CONF_THRESHOLD=0.25

# 单字符区域识别 TorchScript 模型（可选）
# 配置后单支图片切割获取单字符时优先用该模型，否则用 OpenCV 连通域
# 例如自训练导出的 models/best.torchscript
CHAR_TORCHSCRIPT_MODEL_PATH=models/best.torchscript
CHAR_CONF_THRESHOLD=0.25

# YOLOv12 Configuration
YOLOV12_SLIP_MODEL_PATH=models/yolov12n.pt
YOLOV12_CONF_THRESHOLD=0.25
YOLOV12_CLASS_ID=0
